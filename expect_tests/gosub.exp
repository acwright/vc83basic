source [file join [file dirname [info script]] common.expinc]
spawn_basic

# GOSUB

test {
NEW
10 PRINT 1
20 GOSUB 50
30 PRINT 3
40 END
50 PRINT 2
60 RETURN
RUN
} {
1
2
3
}

# Missing line number

test {
NEW
10 PRINT 1
20 GOSUB 40
30 END
RUN
} {
1
ERROR
}

# RETURN without GOSUB

test {
NEW
10 GOSUB 20
20 PRINT 1
30 RETURN
RUN
} {
1
1
ERROR
}

# Infinite GOSUB (will eventually run out of stack space)

test {
NEW
10 PRINT 1
20 PRINT 2
30 GOSUB 20
RUN
} {
1
2
2
2
2
2
2
2
2
2
2
2
2
2
2
ERROR
}

# ON...GOTO

test {
NEW
10 ON 0 GOSUB 40,50,60
20 PRINT 1
30 END
40 PRINT 2
50 PRINT 3
60 PRINT 4
70 RETURN
RUN
} {
2
3
4
}

test {
NEW
10 ON 0 GOSUB 40,50,60
20 PRINT 1
30 END
40 PRINT 2
50 PRINT 3
60 PRINT 4
70 RETURN
RUN
} {
2
3
4
}

test {
NEW
10 ON 0 GOSUB 40,50,60
20 PRINT 1
30 END
40 PRINT 2
50 PRINT 3
60 PRINT 4
70 RETURN
RUN
} {
3
4
}

test {
NEW
10 ON 0 GOSUB 40,50,60
20 PRINT 1
30 END
40 PRINT 2
50 PRINT 3
60 PRINT 4
70 RETURN
RUN
} {
4
}

test {
NEW
10 ON 0 GOSUB 40,50,60
20 PRINT 1
30 END
40 PRINT 2
50 PRINT 3
60 PRINT 4
70 RETURN
RUN
} {
1
}

# POP

test {
NEW
10 GOSUB 20
20 PRINT 1
30 POP
40 RETURN
RUN
} {
1
ERROR
}

# POP without GOSUB

test {
NEW
10 PRINT 1
20 POP
RUN
} {
1
ERROR
}
